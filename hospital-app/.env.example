# Supabase — copy to .env.local and fill in from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the app (used for links inside emails).
# Local: http://localhost:3000 — Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (Resend) — required for appointment confirmation/cancellation/reminder
# emails. Without RESEND_API_KEY, sending is skipped (no error).
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=MediConnect <noreply@yourdomain.com>

# Reminder cron — shared secret Vercel Cron sends as a Bearer token to
# /api/cron/reminders. Generate any long random string.
CRON_SECRET=your-long-random-string
